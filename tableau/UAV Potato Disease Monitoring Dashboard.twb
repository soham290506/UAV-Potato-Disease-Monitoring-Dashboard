            <column caption='Detection Size Category' datatype='string' name='[Calculation_4486502665588736]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF [bbox_area] &lt; 0.2 THEN &quot;Small&quot;&#10;ELSEIF [bbox_area] &lt; 0.6 THEN &quot;Medium&quot;&#10;ELSE &quot;Large&quot;&#10;END' />
            </column>
            <column datatype='real' name='[bbox_area]' role='measure' type='quantitative' />
            <column-instance column='[disease_class]' derivation='Count' name='[cnt:disease_class:qk]' pivot='key' type='quantitative' />
