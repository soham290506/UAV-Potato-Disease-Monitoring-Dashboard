      <column aggregation='None' datatype='integer' name='[Bbox Area (bin)]' role='dimension' type='quantitative'>
        <calculation class='bin' decimals='-2' formula='[bbox_area]' peg='0' size='0.0232' />
      </column>
      <column caption='Detection Size Category' datatype='string' name='[Calculation_4486502665588736]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [bbox_area] &lt; 0.2 THEN &quot;Small&quot;&#10;ELSEIF [bbox_area] &lt; 0.6 THEN &quot;Medium&quot;&#10;ELSE &quot;Large&quot;&#10;END' />
      </column>
      <column caption='Norm Area' datatype='real' name='[Calculation_4486502669418497]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG([bbox_area]) / WINDOW_MAX(AVG([bbox_area]))'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Norm Aspect Ratio' datatype='real' name='[Calculation_4486502669524994]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG([aspect_ratio]) / WINDOW_MAX(AVG([aspect_ratio]))'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Norm Perimeter' datatype='real' name='[Calculation_4486502669631491]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG([bbox_perimeter]) / WINDOW_MAX(AVG([bbox_perimeter]))'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Norm Diagonal' datatype='real' name='[Calculation_4486502669729796]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG([bbox_diagonal]) / WINDOW_MAX(AVG([bbox_diagonal]))'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Norm Center Distance' datatype='real' name='[Calculation_4486502669795333]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG([center_distance]) / WINDOW_MAX(AVG([center_distance]))'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Norm Area Perimeter Ratio' datatype='real' name='[Calculation_4486502669926406]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG([area_to_perimeter_ratio]) /&#10;WINDOW_MAX(AVG([area_to_perimeter_ratio]))'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Feature' datatype='string' name='[Calculation_4486502670180359]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='&quot;Perimeter&quot;' />
      </column>
      <column caption='Strongest Feature' datatype='string' name='[Calculation_4486502676443144]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='&quot;BBox Perimeter&quot;' />
      </column>
      <column caption='One' datatype='integer' name='[Calculation_4486503737446409]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='1' />
      </column>
      <column aggregation='CountD' caption='Profile_Early' datatype='string' default-role='measure' default-type='quantitative' name='[Calculation_4486503742210058]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='&quot;EARLY BLIGHT&#10;&#10;Largest Detection Footprint&#10;&#10;• Highest Avg Area (0.795)&#10;&#10;• Highest Avg Perimeter (3.473)&#10;&#10;• Highest Avg Diagonal (1.230)&#10;&#10;Early Blight lesions occupy the largest visible region among all disease classes.&quot;' />
      </column>
      <column caption='Early_Text' datatype='string' name='[Calculation_4486503744811019]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='&quot;EARLY BLIGHT&#10;&#10;Largest Detection Footprint&#10;&#10;• Highest Avg Area (0.795)&#10;&#10;• Highest Avg Perimeter (3.473)&#10;&#10;• Highest Avg Diagonal (1.230)&#10;&#10;Early Blight lesions occupy the largest visible region among all disease classes.&quot;' />
      </column>
      <column caption='X region' datatype='string' name='[Calculation_4486504436195349]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [x_center] &lt; 0.33 THEN &quot;Left&quot;&#10;&#10;ELSEIF [x_center] &lt; 0.66 THEN &quot;Center&quot;&#10;&#10;ELSE &quot;Right&quot;&#10;&#10;END' />
      </column>
      <column caption='Y region' datatype='string' name='[Calculation_4486504436355094]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [y_center] &lt; 0.33 THEN &quot;Top&quot;&#10;&#10;ELSEIF [y_center] &lt; 0.66 THEN &quot;Middle&quot;&#10;&#10;ELSE &quot;Bottom&quot;&#10;&#10;END' />
      </column>
      <column caption='Spatial Zone' datatype='string' name='[Calculation_4486504436523031]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='[Calculation_4486504436355094] + &quot; &quot; + [Calculation_4486504436195349]' />
      </column>
      <column caption='Distance Ring' datatype='string' name='[Calculation_4486504438255640]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [center_distance] &lt;= 0.10 THEN &quot;0.00 - 0.10&quot;&#10;&#10;ELSEIF [center_distance] &lt;= 0.20 THEN &quot;0.10 - 0.20&quot;&#10;&#10;ELSEIF [center_distance] &lt;= 0.30 THEN &quot;0.20 - 0.30&quot;&#10;&#10;ELSEIF [center_distance] &lt;= 0.40 THEN &quot;0.30 - 0.40&quot;&#10;&#10;ELSE &quot;0.40+&quot;&#10;&#10;END' />
      </column>
      <column caption='Disease Short' datatype='string' name='[Calculation_4486504447885337]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='CASE [disease_class]&#10;&#10;WHEN &quot;Potato_Early_Blight&quot; THEN &quot;Early&quot;&#10;&#10;WHEN &quot;Potato_Late_Blight&quot; THEN &quot;Late&quot;&#10;&#10;WHEN &quot;Potato_Healthy_Plant&quot; THEN &quot;Healthy&quot;&#10;&#10;END' />
      </column>
